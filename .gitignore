# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.*.local

# but allow .env.example to be committed
!.env.example

# vercel
.vercel

# e2e
/e2e/test-results/
/e2e/playwright-report/
/test-results/
/playwright-report/

# local uploaded source files
/uploads/

# typescript
*.tsbuildinfo
next-env.d.ts

.night-shift/

# Python venv for editable-ppt renderer
scripts/.venv/
scripts/test-manifest.json
