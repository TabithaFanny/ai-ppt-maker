OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.bltcy.ai/v1

# Fallback: codesuc relay (gpt-image-2 only)
# OPENAI_BASE_URL_FALLBACK=https://main-new.codesuc.top/v1
